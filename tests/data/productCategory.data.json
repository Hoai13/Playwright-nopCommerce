{
  "URLS": {
    "HOME": "https://demo.nopcommerce.com/"
  },
  "MESSAGES": {
    "ADD_WISHLIST_SUCCESS": "The product has been added to your wishlist",
    "ADD_COMPARE_SUCCESS": "The product has been added to your product comparison",
    "NO_PRODUCTS": "No products were found"
  },
  "PRODUCTS": {
    "NOTEBOOK": "Apple MacBook Pro",
    "CONFIGURABLE": "Build your own computer",
    "SIMPLE": "Asus Laptop"
  },
  "CASES": [
    {
      "id": "PC-001",
      "description": "Navigate to category page",
      "input": {
        "category": "Computers"
      },
      "expected": {
        "title": "Computers",
        "breadcrumb": "Home / Computers",
        "subCategories": [
          "Desktops",
          "Notebooks",
          "Software"
        ]
      }
    },
    {
      "id": "PC-004",
      "description": "Navigate to sub-category page",
      "input": {
        "category": "Computers",
        "subCategory": "Notebooks"
      },
      "expected": {
        "title": "Notebooks",
        "breadcrumb": "Home / Computers / Notebooks"
      }
    },
    {
      "id": "PC-014",
      "description": "Open product detail page",
      "input": {
        "category": "Computers",
        "subCategory": "Notebooks",
        "product": "Apple MacBook Pro"
      },
      "expected": {
        "urlContains": "apple-macbook-pro"
      }
    },
    {
      "id": "PC-017",
      "description": "Add product to wishlist",
      "input": {
        "category": "Computers",
        "subCategory": "Notebooks",
        "product": "Asus Laptop"
      },
      "expected": {
        "notification": "ADD_WISHLIST_SUCCESS"
      }
    },
    {
      "id": "PC-018",
      "description": "Require configuration before add wishlist",
      "input": {
        "category": "Computers",
        "subCategory": "Desktops",
        "product": "Build your own computer"
      },
      "expected": {
        "urlContains": "build-your-own-computer"
      }
    },
    {
      "id": "PC-019",
      "description": "Add product to compare list",
      "input": {
        "category": "Computers",
        "subCategory": "Notebooks",
        "product": "Asus Laptop"
      },
      "expected": {
        "notification": "ADD_COMPARE_SUCCESS"
      }
    }
  ]
}