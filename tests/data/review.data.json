{
  "URLS": {
    "HOME": "https://demo.nopcommerce.com/",
    "REGISTER": "https://demo.nopcommerce.com/register"
  },
  "PRODUCT": {
    "CATEGORY": "Computers",
    "SUB_CATEGORY": "Notebooks",
    "NAME": "Apple MacBook Pro"
  },
  "REGISTER_USER": {
    "firstName": "auto",
    "lastName": "review",
    "password": "123456",
    "confirmPassword": "123456",
    "emailPrefix": "rv"
  },
  "MESSAGES": {
    "REVIEW_SUCCESS": "Product review is successfully added.",
    "TITLE_REQUIRED": "Review title is required",
    "TEXT_REQUIRED": "Review text is required",
    "TITLE_RANGE": "Max length of product review title is 200 chars",
    "VOTE_GUEST_ERROR": "Only registered users can vote",
    "VOTE_OWN_ERROR": "You cannot vote for your own review"
  },
  "VALUES": {
    "TITLE_201": "__LONG_TEXT_201__",
    "TITLE_200": "__LONG_TEXT_200__",
    "SPECIAL_TITLE": "S&",
    "SPECIAL_TEXT": "#$%&**"
  },
  "CASES": [
    { "id": "RV-001", "flow": "viewWithoutLogin" },
    {
      "id": "RV-002",
      "flow": "submitReview",
      "requiresLogin": true,
      "review": { "title": "Excellent Camera", "text": "Great image quality", "rating": 5 },
      "expect": { "success": true, "containsTitle": "Excellent Camera" }
    },
    {
      "id": "RV-003",
      "flow": "submitReview",
      "requiresLogin": true,
      "review": { "title": "", "text": "Valid text", "rating": 4 },
      "expect": { "errorKey": "TITLE_REQUIRED" }
    },
   {
      "id": "RV-004",
      "flow": "submitReview",
      "requiresLogin": true,
      "review": { "title": "SPECIAL_TITLE", "text": "Good camera", "rating": 4 },
      "expect": { "success": true }
    },
    {
      "id": "RV-005",
      "flow": "submitReview",
      "requiresLogin": true,
      "review": { "title": "TITLE_201", "text": "Boundary test", "rating": 4 },
      "expect": { "errorKey": "TITLE_RANGE" }
    },
    {
      "id": "RV-011",
      "flow": "submitReview",
      "requiresLogin": true,
      "review": { "title": "Default Rating", "text": "No rating selected" },
      "expect": { "success": true }
    }
  ]
}